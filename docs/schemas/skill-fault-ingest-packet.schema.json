{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scafforge.local/meta-skill-engineering/skill-fault-ingest-packet.schema.json",
  "title": "Skill Fault Ingest Packet",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "candidate_id", "failure_family", "summary", "evidence"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "failure_family": {
      "type": "string",
      "enum": ["skill-fault", "skill-faults", "skill_fault"]
    },
    "source_archive_path": {
      "type": "string"
    },
    "reported_at": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "minLength": 20
    },
    "impact": {
      "type": "string"
    },
    "target_skill": {
      "type": "string"
    },
    "suggested_skill_name": {
      "type": "string"
    },
    "routing_hints": {
      "type": "object",
      "additionalProperties": true
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["kind"],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "excerpt": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["info", "low", "medium", "high", "critical"]
          }
        },
        "anyOf": [
          {
            "required": ["path"]
          },
          {
            "required": ["url"]
          },
          {
            "required": ["excerpt"]
          }
        ]
      }
    }
  }
}
