<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MetaSkillStudio.Views.AnalyticsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="Analytics Dashboard" 
        Height="800" 
        Width="1200"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Analytics Dashboard" 
                          FontSize="24" 
                          FontWeight="SemiBold"
                          Foreground="{StaticResource PrimaryBrush}"
                          AutomationProperties.Name="Analytics Dashboard Header"/>
                <TextBlock Text="Skill health, trends, and performance metrics" 
                          FontSize="13"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1"
                   Style="{StaticResource PrimaryButton}"
                   Command="{Binding RefreshCommand}"
                   VerticalAlignment="Center"
                   Width="100"
                   ToolTip="Refresh analytics data from latest runs (Alt+R)"
                   AutomationProperties.Name="Refresh Analytics"
                   AutomationProperties.HelpText="Refresh analytics data"
                   TabIndex="0">
                <AccessText>_Refresh</AccessText>
            </Button>
        </Grid>
        
        <!-- Main Content -->
        <TabControl Grid.Row="1" Background="Transparent" TabIndex="0">
            <!-- Overview Tab -->
            <TabItem Header="Overview" ToolTip="Summary view with alerts and key metrics" TabIndex="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <!-- Alerts Section -->
                    <Border Grid.Row="0" 
                           Background="{StaticResource SurfaceBrush}"
                           BorderBrush="{StaticResource BorderBrush}"
                           BorderThickness="1"
                           CornerRadius="8"
                           Padding="16"
                           Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" 
                                      Text="Alerts" 
                                      FontSize="16" 
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,12"
                                      AutomationProperties.Name="Alerts Section"/>
                            
                            <!-- Empty State for Alerts -->
                            <TextBlock Grid.Row="1" 
                                      Text="No alerts at this time"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      Visibility="{Binding Alerts.Count, Converter={StaticResource CountToVisibilityConverter}}"
                                      AutomationProperties.Name="No alerts message"/>
                            
                            <ItemsControl Grid.Row="1" 
                                         ItemsSource="{Binding Alerts}"
                                         AutomationProperties.Name="Alerts List">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding SeverityColor}" 
                                               Opacity="0.1"
                                               CornerRadius="4"
                                               Padding="12,8"
                                               Margin="0,4,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" 
                                                        Width="12" 
                                                        Height="12" 
                                                        Fill="{Binding SeverityColor}"
                                                        Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="1">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0}: {1}">
                                                            <Binding Path="SkillName" />
                                                            <Binding Path="Message" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                    
                    <!-- Skills Health Grid -->
                    <Border Grid.Row="1" 
                           Background="{StaticResource SurfaceBrush}"
                           BorderBrush="{StaticResource BorderBrush}"
                           BorderThickness="1"
                           CornerRadius="8"
                           Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" 
                                      Text="Skill Health Overview" 
                                      FontSize="16" 
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,12"
                                      AutomationProperties.Name="Skill Health Overview Section"/>
                            
                            <!-- Empty State for Skill Analytics -->
                            <TextBlock Grid.Row="1" 
                                      Text="No data available. Run skills to see analytics."
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      TextWrapping="Wrap"
                                      Margin="16"
                                      Visibility="{Binding SkillAnalytics.Count, Converter={StaticResource CountToVisibilityConverter}}"
                                      AutomationProperties.Name="No data available message"/>
                            
                            <DataGrid Grid.Row="1"
                                     ItemsSource="{Binding SkillAnalytics}"
                                     AutoGenerateColumns="False"
                                     IsReadOnly="True"
                                     GridLinesVisibility="Horizontal"
                                     BorderThickness="0"
                                     HeadersVisibility="Column"
                                     AutomationProperties.Name="Skill Health Data Grid"
                                     TabIndex="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Skill" 
                                                       Binding="{Binding SkillName}" 
                                                       Width="*"/>
                                    <DataGridTextColumn Header="Total Runs" 
                                                       Binding="{Binding TotalRuns}" 
                                                       Width="Auto"/>
                                    <DataGridTextColumn Header="Pass Rate" 
                                                       Binding="{Binding SuccessRate, StringFormat='{}{0:F1}%'}" 
                                                       Width="Auto"/>
                                    <DataGridTextColumn Header="Quality" 
                                                       Binding="{Binding AverageQualityScore, StringFormat='{}{0:F0}'}" 
                                                       Width="Auto"/>
                                    <DataGridTextColumn Header="Last Run" 
                                                       Binding="{Binding LastRunAt, StringFormat='{}{0:MM/dd HH:mm}'}" 
                                                       Width="Auto"/>
                                    <DataGridTextColumn Header="Trend" 
                                                       Binding="{Binding Trend}" 
                                                       Width="Auto"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Charts Tab -->
            <TabItem Header="Trends" TabIndex="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- Pass Rate Chart -->
                    <Border Grid.Row="0" 
                           Grid.Column="0"
                           Background="{StaticResource SurfaceBrush}"
                           BorderBrush="{StaticResource BorderBrush}"
                           BorderThickness="1"
                           CornerRadius="8"
                           Padding="16"
                           Margin="0,0,8,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" 
                                      Text="Pass Rate by Skill" 
                                      FontSize="14" 
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,8"
                                      AutomationProperties.Name="Pass Rate Chart Header"/>
                            
                            <!-- Empty State for Pass Rate Chart -->
                            <TextBlock Grid.Row="1" 
                                      Text="No data available"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      Visibility="{Binding HasPassRateData, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                      AutomationProperties.Name="No pass rate data message"/>
                            
                            <scottplot:WpfPlot Grid.Row="1" 
                                              x:Name="PassRatePlot"
                                              Visibility="{Binding HasPassRateData, Converter={StaticResource BoolToVisibilityConverter}}"
                                              AutomationProperties.Name="Pass Rate Chart"/>
                        </Grid>
                    </Border>
                    
                    <!-- Quality Score Chart -->
                    <Border Grid.Row="0" 
                           Grid.Column="1"
                           Background="{StaticResource SurfaceBrush}"
                           BorderBrush="{StaticResource BorderBrush}"
                           BorderThickness="1"
                           CornerRadius="8"
                           Padding="16"
                           Margin="8,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" 
                                      Text="Average Quality Score by Skill" 
                                      FontSize="14" 
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,8"
                                      AutomationProperties.Name="Quality Score Chart Header"/>
                            
                            <!-- Empty State for Quality Score Chart -->
                            <TextBlock Grid.Row="1" 
                                      Text="No data available"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      Visibility="{Binding HasQualityData, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                      AutomationProperties.Name="No quality data message"/>
                            
                            <scottplot:WpfPlot Grid.Row="1" 
                                              x:Name="QualityScorePlot"
                                              Visibility="{Binding HasQualityData, Converter={StaticResource BoolToVisibilityConverter}}"
                                              AutomationProperties.Name="Quality Score Chart"/>
                        </Grid>
                    </Border>
                    
                    <!-- Run Count Chart -->
                    <Border Grid.Row="1" 
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Background="{StaticResource SurfaceBrush}"
                           BorderBrush="{StaticResource BorderBrush}"
                           BorderThickness="1"
                           CornerRadius="8"
                           Padding="16"
                           Margin="0,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" 
                                      Text="Run Activity (Last 30 Days)" 
                                      FontSize="14" 
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,8"
                                      AutomationProperties.Name="Run Activity Chart Header"/>
                            
                            <!-- Empty State for Activity Chart -->
                            <TextBlock Grid.Row="1" 
                                      Text="No data available"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      Visibility="{Binding HasActivityData, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                      AutomationProperties.Name="No activity data message"/>
                            
                            <scottplot:WpfPlot Grid.Row="1" 
                                              x:Name="ActivityPlot" 
                                              Height="200"
                                              Visibility="{Binding HasActivityData, Converter={StaticResource BoolToVisibilityConverter}}"
                                              AutomationProperties.Name="Run Activity Chart"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- Loading Overlay -->
        <Border Grid.Row="1" 
               Background="#80FFFFFF"
               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
               CornerRadius="8"
               IsHitTestVisible="False"
               AutomationProperties.Name="Loading overlay"
               AutomationProperties.HelpText="Analytics data is loading">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="100" Height="4" Margin="0,0,0,8"/>
                <TextBlock Text="Loading analytics..." 
                          Foreground="{StaticResource TextSecondaryBrush}"
                          AutomationProperties.Name="Loading message"
                          AutomationProperties.LiveSetting="Polite"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
