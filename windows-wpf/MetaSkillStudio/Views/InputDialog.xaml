<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MetaSkillStudio.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" 
        Height="200" 
        Width="500"
        MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" 
                  Text="{Binding Message}" 
                  FontSize="14"
                  Margin="0,0,0,12"
                  TextWrapping="Wrap"
                  AutomationProperties.Name="Dialog Message"
                  AutomationProperties.LiveSetting="Polite"/>
        
        <TextBox Grid.Row="1"
                Text="{Binding ResponseText, UpdateSourceTrigger=PropertyChanged}"
                Margin="0,0,0,16"
                Height="32"
                VerticalContentAlignment="Center"
                Padding="8,0"
                Validation.ErrorTemplate="{StaticResource ErrorTemplate}"
                ToolTip="Type your response or input"
                AutomationProperties.Name="Response Input"
                AutomationProperties.HelpText="Enter your response here"
                TabIndex="0"/>
        
        <StackPanel Grid.Row="2" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right">
            <Button Style="{StaticResource PrimaryButton}"
                   Click="OkButton_Click"
                   IsDefault="True"
                   Width="80"
                   Margin="0,0,8,0"
                   ToolTip="Confirm and close (Alt+O, Enter)"
                   AutomationProperties.Name="OK"
                   AutomationProperties.HelpText="Confirm and close dialog"
                   TabIndex="0">
                <AccessText>_OK</AccessText>
            </Button>
            <Button Style="{StaticResource SecondaryButton}"
                   Click="CancelButton_Click"
                   IsCancel="True"
                   Width="80"
                   ToolTip="Cancel and close (Alt+C, Esc)"
                   AutomationProperties.Name="Cancel"
                   AutomationProperties.HelpText="Cancel and close dialog"
                   TabIndex="0">
                <AccessText>_Cancel</AccessText>
            </Button>
        </StackPanel>
    </Grid>
</Window>
