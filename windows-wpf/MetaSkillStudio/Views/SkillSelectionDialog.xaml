<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MetaSkillStudio.Views.SkillSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Select Skill" 
        Height="400" 
        Width="500"
        MinWidth="400"
        MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Select Skill" 
                      FontSize="18" 
                      FontWeight="SemiBold"
                      Foreground="{StaticResource PrimaryBrush}"
                      AutomationProperties.Name="Select Skill Header"/>
            <TextBlock x:Name="DescriptionText"
                      Text="Choose a skill from the list below." 
                      FontSize="12"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Search -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" 
                      Text="Search:" 
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"/>
            <TextBox Grid.Column="1"
                    x:Name="SearchBox"
                    TextChanged="SearchBox_TextChanged"
                    VerticalContentAlignment="Center"
                    Padding="8,6"
                    ToolTip="Type to filter skills by name or description"
                    AutomationProperties.Name="Search Skills"
                    AutomationProperties.HelpText="Type to filter the skill list"
                    TabIndex="0"/>
        </Grid>
        
        <!-- Skill List -->
        <Border Grid.Row="2" 
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <!-- Empty State -->
                <TextBlock Text="No skills match your search"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          TextWrapping="Wrap"
                          Margin="16"
                          Visibility="Collapsed"
                          x:Name="EmptyStateText"
                          AutomationProperties.Name="Empty State: No skills match your search"/>
                
                <ListBox x:Name="SkillListBox"
                        SelectionChanged="SkillListBox_SelectionChanged"
                        BorderThickness="0"
                        Background="Transparent"
                        ToolTip="Click to select a skill, double-click to choose"
                        AutomationProperties.Name="Skill List"
                        AutomationProperties.HelpText="Select a skill from the list"
                        TabIndex="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" Background="Transparent">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" 
                                              Text="{Binding Name}" 
                                              FontWeight="SemiBold"
                                              FontSize="13"
                                              AutomationProperties.Name="{Binding Name}"/>
                                    <TextBlock Grid.Row="1" 
                                              Text="{Binding Description}" 
                                              FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              TextTrimming="CharacterEllipsis"
                                              MaxWidth="400"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
        
        <!-- Optional: Test All Skills -->
        <CheckBox Grid.Row="2"
                 x:Name="TestAllCheckBox"
                 Content="Test all skills (no selection required)"
                 Margin="0,8,0,8"
                 VerticalAlignment="Bottom"
                 Checked="TestAllCheckBox_Checked"
                 Unchecked="TestAllCheckBox_Unchecked"
                 ToolTip="Run tests on all skills instead of just the selected one"
                 AutomationProperties.Name="Test all skills"
                 AutomationProperties.HelpText="Check to test all skills without selecting one"
                 TabIndex="0"/>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="3" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right"
                   Margin="0,32,0,0">
            <Button Style="{StaticResource PrimaryButton}"
                   Click="OkButton_Click"
                   Width="80"
                   Margin="0,0,8,0"
                   IsDefault="True"
                   ToolTip="Confirm selection and proceed (Alt+O, Enter)"
                   AutomationProperties.Name="OK"
                   AutomationProperties.HelpText="Confirm skill selection"
                   TabIndex="0">
                <AccessText>_OK</AccessText>
            </Button>
            <Button Style="{StaticResource SecondaryButton}"
                   Click="CancelButton_Click"
                   IsCancel="True"
                   Width="80"
                   ToolTip="Cancel and close (Alt+C, Esc)"
                   AutomationProperties.Name="Cancel"
                   AutomationProperties.HelpText="Cancel skill selection"
                   TabIndex="0">
                <AccessText>_Cancel</AccessText>
            </Button>
        </StackPanel>
    </Grid>
</Window>
