<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MetaSkillStudio.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Meta Skill Studio" 
        Height="800" 
        Width="1200"
        MinWidth="800"
        MinHeight="600"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Meta Skill Studio" 
                              FontSize="20" 
                              FontWeight="SemiBold"
                              Foreground="{StaticResource PrimaryBrush}"
                              AutomationProperties.Name="Application Title Meta Skill Studio"/>
                    <TextBlock Text=" - AI Skill Management" 
                              FontSize="14"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              VerticalAlignment="Bottom"
                              Margin="8,0,0,2"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding OpenAnalyticsCommand}"
                            ToolTip="View skill health analytics and trends (Alt+A)"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="Analytics"
                            AutomationProperties.HelpText="Opens the analytics dashboard to view skill health metrics"
                            TabIndex="0">
                        <AccessText>_Analytics</AccessText>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding RefreshSkillsCommand}"
                            ToolTip="Reload skill list from repository (Alt+R)"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="Refresh Skills"
                            AutomationProperties.HelpText="Reloads the skill list from the repository"
                            TabIndex="0">
                        <AccessText>_Refresh Skills</AccessText>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding OpenSettingsCommand}"
                            ToolTip="Configure runtimes and models (Alt+S)"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="Settings"
                            AutomationProperties.HelpText="Opens settings dialog to configure AI runtimes and models"
                            TabIndex="0">
                        <AccessText>_Settings</AccessText>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding RefreshRunsCommand}"
                            ToolTip="Refresh run history (Alt+U)"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="Refresh Runs"
                            AutomationProperties.HelpText="Refreshes the run history list"
                            TabIndex="0">
                        <AccessText>Refresh R_uns</AccessText>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <!-- Left Panel: Actions -->
            <Border Grid.Column="0" 
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Actions" 
                              FontSize="16" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"
                              AutomationProperties.Name="Actions Section"/>
                    
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding CreateSkillCommand}"
                            ToolTip="Create a new skill in LibraryUnverified or LibraryWorkbench (Alt+C)"
                            Margin="0,0,0,8"
                            Height="36"
                            AutomationProperties.Name="Create Skill"
                            AutomationProperties.HelpText="Opens dialog to create a new skill"
                            TabIndex="0">
                        <AccessText>_Create Skill</AccessText>
                    </Button>
                    
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding ImproveSkillCommand}"
                            ToolTip="Improve an existing skill with a specific goal (Alt+I)"
                            Margin="0,0,0,8"
                            Height="36"
                            AutomationProperties.Name="Improve Skill"
                            AutomationProperties.HelpText="Opens dialog to improve an existing skill"
                            TabIndex="0">
                        <AccessText>_Improve Skill</AccessText>
                    </Button>
                    
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding TestBenchmarkCommand}"
                            ToolTip="Run validation, evaluation, and judge on a skill or all skills (Alt+T)"
                            Margin="0,0,0,8"
                            Height="36"
                            AutomationProperties.Name="Test Benchmark"
                            AutomationProperties.HelpText="Run tests and benchmarks on skills"
                            TabIndex="0">
                        <AccessText>_Test / Benchmark</AccessText>
                    </Button>
                    
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding MetaManageCommand}"
                            ToolTip="Execute meta-library management operations (Alt+M)"
                            Margin="0,0,0,8"
                            Height="36"
                            AutomationProperties.Name="Meta Manage"
                            AutomationProperties.HelpText="Execute meta-library management operations"
                            TabIndex="0">
                        <AccessText>_Meta Manage</AccessText>
                    </Button>
                    
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding CreateBenchmarksCommand}"
                            ToolTip="Generate benchmark test cases for a skill (Alt+B)"
                            Margin="0,0,0,24"
                            Height="36"
                            AutomationProperties.Name="Create Benchmarks"
                            AutomationProperties.HelpText="Generate benchmark test cases for a skill"
                            TabIndex="0">
                        <AccessText>Create _Benchmarks</AccessText>
                    </Button>
                    
                    <Separator Margin="0,0,0,16"/>
                    
                    <TextBlock Text="Run History" 
                              FontSize="14" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,8"
                              AutomationProperties.Name="Run History Section"/>
                    
                    <!-- Empty State for Run History -->
                    <Grid>
                        <TextBlock Text="No runs recorded yet"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  TextWrapping="Wrap"
                                  Margin="8"
                                  Visibility="{Binding RunHistory.Count, Converter={StaticResource CountToVisibilityConverter}}"
                                  AutomationProperties.Name="Empty State: No runs recorded yet"/>
                        
                        <ListBox ItemsSource="{Binding RunHistory}"
                                SelectedItem="{Binding SelectedRun}"
                                BorderThickness="0"
                                Background="Transparent"
                                MaxHeight="300"
                                AutomationProperties.Name="Run History List"
                                AutomationProperties.HelpText="List of previous skill runs. Select a run to view details"
                                TabIndex="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" 
                                           Background="Transparent"
                                           CornerRadius="4">
                                        <TextBlock Text="{Binding DisplayName}" 
                                                  TextTrimming="CharacterEllipsis"
                                                  AutomationProperties.Name="{Binding DisplayName}"/>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Right Panel: Output -->
            <Border Grid.Column="1" 
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Output" 
                              FontSize="16" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,12"
                              AutomationProperties.Name="Output Section"/>
                    
                    <Border Grid.Row="1" 
                            Background="#1E1E1E"
                            CornerRadius="4"
                            Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding OutputText}"
                                      FontFamily="Consolas, Courier New, monospace"
                                      FontSize="12"
                                      Foreground="#D4D4D4"
                                      TextWrapping="Wrap"
                                      AutomationProperties.Name="Output Text"
                                      AutomationProperties.LiveSetting="Polite"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="2" 
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <!-- Runtime Status -->
                <Border Grid.Column="0" 
                        Background="{StaticResource BackgroundBrush}"
                        CornerRadius="4"
                        Padding="8,4"
                        Margin="0,0,16,0">
                    <TextBlock Text="{Binding RuntimeStatus}" 
                              FontSize="12"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              AutomationProperties.Name="Runtime Status"/>
                </Border>
                
                <!-- Status Message -->
                <TextBlock Grid.Column="1" 
                          Text="{Binding StatusText}" 
                          Foreground="{StaticResource TextSecondaryBrush}"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="Status Message"
                          AutomationProperties.LiveSetting="Polite"/>
                
                <!-- Skill Count -->
                <TextBlock Grid.Column="2" 
                          Text="{Binding AvailableSkills.Count, StringFormat='{}{0} skills'}"
                          FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0"
                          AutomationProperties.Name="Skill Count"/>
                
                <!-- Progress -->
                <ProgressBar Grid.Column="3" 
                            IsIndeterminate="{Binding IsBusy}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                            Width="100"
                            Height="4"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Progress Indicator"
                            AutomationProperties.HelpText="Shows when application is busy processing"/>
            </Grid>
        </Border>
    </Grid>
</Window>
