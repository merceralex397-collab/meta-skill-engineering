<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MetaSkillStudio.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:MetaSkillStudio.Models"
        mc:Ignorable="d"
        Title="Meta Skill Studio"
        Height="900" Width="1400"
        MinWidth="1060" MinHeight="720"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Nav Rail -->
            <ColumnDefinition Width="56" />
            <!-- Content Area -->
            <ColumnDefinition Width="*" />
            <!-- Assistant Panel (collapsible) -->
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════ -->
        <!-- LEFT: Navigation Rail                       -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource NavRailBgBrush}">
            <DockPanel>
                <!-- App icon at top -->
                <TextBlock DockPanel.Dock="Top" Text="MSS" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource NavRailTextActiveBrush}"
                           HorizontalAlignment="Center" Margin="0,14,0,10" />

                <!-- Settings at bottom -->
                <RadioButton DockPanel.Dock="Bottom" Style="{StaticResource NavRailButton}"
                             ToolTip="Settings" Margin="0,0,0,8"
                             IsChecked="{Binding SelectedPage, Converter={StaticResource EqualityConverter}, ConverterParameter=Settings}">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                </RadioButton>

                <!-- Nav items -->
                <StackPanel VerticalAlignment="Top" Margin="0,4,0,0">
                    <RadioButton Style="{StaticResource NavRailButton}" ToolTip="Dashboard"
                                 IsChecked="{Binding SelectedPage, Converter={StaticResource EqualityConverter}, ConverterParameter=Dashboard}">
                        <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavRailButton}" ToolTip="Skill Library"
                                 IsChecked="{Binding SelectedPage, Converter={StaticResource EqualityConverter}, ConverterParameter=Library}">
                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavRailButton}" ToolTip="Create Skill"
                                 IsChecked="{Binding SelectedPage, Converter={StaticResource EqualityConverter}, ConverterParameter=Create}">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavRailButton}" ToolTip="Improve Skill"
                                 IsChecked="{Binding SelectedPage, Converter={StaticResource EqualityConverter}, ConverterParameter=Improve}">
                        <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavRailButton}" ToolTip="Test &amp; Evaluate"
                                 IsChecked="{Binding SelectedPage, Converter={StaticResource EqualityConverter}, ConverterParameter=Test}">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavRailButton}" ToolTip="Automation"
                                 IsChecked="{Binding SelectedPage, Converter={StaticResource EqualityConverter}, ConverterParameter=Automation}">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavRailButton}" ToolTip="Import Skills"
                                 IsChecked="{Binding SelectedPage, Converter={StaticResource EqualityConverter}, ConverterParameter=Import}">
                        <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavRailButton}" ToolTip="Library Management"
                                 IsChecked="{Binding SelectedPage, Converter={StaticResource EqualityConverter}, ConverterParameter=Manage}">
                        <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavRailButton}" ToolTip="Analytics"
                                 IsChecked="{Binding SelectedPage, Converter={StaticResource EqualityConverter}, ConverterParameter=Analytics}">
                        <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- CENTER: Content Area                        -->
        <!-- ═══════════════════════════════════════════ -->
        <DockPanel Grid.Column="1">
            <!-- Status Bar at bottom -->
            <Border DockPanel.Dock="Bottom" Background="{StaticResource NavRailBgBrush}" Height="26">
                <DockPanel Margin="12,0">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding RuntimeStatusDisplay}" Foreground="{StaticResource NavRailTextBrush}" FontSize="11" />
                    </StackPanel>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource NavRailTextBrush}" FontSize="11"
                               HorizontalAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right" />
                    <TextBlock Text="{Binding LibrarySkillCount, StringFormat='{}{0} skills'}"
                               Foreground="{StaticResource NavRailTextBrush}" FontSize="11"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <!-- Top Bar -->
            <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Height="44">
                <DockPanel Margin="16,0">
                    <TextBlock Text="Meta Skill Studio" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" DockPanel.Dock="Left" />
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource IconButton}" Command="{Binding RefreshLibraryCommand}"
                                ToolTip="Refresh Library" Margin="4,0">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        </Button>
                        <Button Style="{StaticResource IconButton}" Command="{Binding ToggleAssistantCommand}"
                                ToolTip="Toggle AI Assistant" Margin="4,0">
                            <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        </Button>
                    </StackPanel>
                    <!-- Busy indicator -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="⟳" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content Pages -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="24,20">
                <Grid>

                    <!-- ══════════════ DASHBOARD ══════════════ -->
                    <StackPanel Visibility="{Binding SelectedPage, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Dashboard}">
                        <TextBlock Text="Dashboard" Style="{StaticResource PageTitle}" />

                        <!-- Quick Actions -->
                        <TextBlock Text="Quick Actions" Style="{StaticResource SectionHeader}" />
                        <UniformGrid Columns="4" Margin="0,0,0,24">
                            <Button Style="{StaticResource WorkflowCardButton}" Margin="0,0,12,0"
                                    Command="{Binding CreateSkillCommand}">
                                <StackPanel>
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                               Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="Create Skill" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,2" />
                                    <TextBlock Text="Build a new AI skill" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource WorkflowCardButton}" Margin="6,0"
                                    Command="{Binding ImproveSkillCommand}">
                                <StackPanel>
                                    <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                               Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="Improve Skill" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,2" />
                                    <TextBlock Text="Refine an existing skill" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource WorkflowCardButton}" Margin="6,0"
                                    Command="{Binding TestBenchmarkCommand}">
                                <StackPanel>
                                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                               Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="Test Skills" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,2" />
                                    <TextBlock Text="Run tests and benchmarks" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource WorkflowCardButton}" Margin="12,0,0,0"
                                    Command="{Binding NavigateCommand}" CommandParameter="{x:Static models:StudioPage.Library}">
                                <StackPanel>
                                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="Browse Library" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,2" />
                                    <TextBlock Text="View all skills" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>

                        <!-- Library Summary -->
                        <TextBlock Text="Library Overview" Style="{StaticResource SectionHeader}" />
                        <UniformGrid Columns="3" Margin="0,0,0,24">
                            <Border Style="{StaticResource ContentCard}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Unverified" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding LibraryUnverifiedCount}" FontSize="28" FontWeight="Bold"
                                               Foreground="{StaticResource WarningBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ContentCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="In Testing" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding LibraryTestingCount}" FontSize="28" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ContentCard}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Verified" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding LibraryVerifiedCount}" FontSize="28" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Recent Activity / Output -->
                        <TextBlock Text="Activity Log" Style="{StaticResource SectionHeader}" />
                        <Border Style="{StaticResource ContentCard}" MaxHeight="240">
                            <TextBox Text="{Binding OutputText, Mode=OneWay}" IsReadOnly="True"
                                     FontFamily="Cascadia Code,Consolas" FontSize="12"
                                     Background="Transparent" BorderThickness="0"
                                     VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                                     Foreground="{StaticResource TextPrimaryBrush}" />
                        </Border>
                    </StackPanel>

                    <!-- ══════════════ SKILL LIBRARY ══════════════ -->
                    <Grid Visibility="{Binding SelectedPage, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Library}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Skill Library" Style="{StaticResource PageTitle}" />

                        <!-- Tier tabs + Search -->
                        <DockPanel Grid.Row="1" Margin="0,0,0,16">
                            <TextBox DockPanel.Dock="Right" Width="200" Text="{Binding LibrarySearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource StudioTextBox}" Margin="12,0,0,0" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="{Binding LibraryUnverifiedCount, StringFormat='Unverified ({0})'}"
                                             GroupName="LibTier" IsChecked="True" Margin="0,0,16,0" FontSize="13" Cursor="Hand"
                                             Checked="LibTierUnverified_Checked" />
                                <RadioButton Content="{Binding LibraryTestingCount, StringFormat='In Testing ({0})'}"
                                             GroupName="LibTier" Margin="0,0,16,0" FontSize="13" Cursor="Hand"
                                             Checked="LibTierTesting_Checked" />
                                <RadioButton Content="{Binding LibraryVerifiedCount, StringFormat='Verified ({0})'}"
                                             GroupName="LibTier" FontSize="13" Cursor="Hand"
                                             Checked="LibTierVerified_Checked" />
                            </StackPanel>
                        </DockPanel>

                        <!-- Skills list + detail -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Category + Skill List -->
                            <Border Grid.Column="0" Style="{StaticResource ContentCard}" Margin="0,0,12,0" Padding="8">
                                <ListBox ItemsSource="{Binding FilteredLibraryEntries}"
                                         SelectedItem="{Binding SelectedLibraryEntry}"
                                         VirtualizingStackPanel.IsVirtualizing="True"
                                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         BorderThickness="0" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4,6">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding CategoryDisplay}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <!-- Skill Detail -->
                            <Border Grid.Column="1" Style="{StaticResource ContentCard}" Padding="16">
                                <DockPanel>
                                    <!-- Actions toolbar at top -->
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                                        <Button Style="{StaticResource SecondaryButton}" Content="Test"
                                                Command="{Binding InlineTestSkillCommand}" Margin="0,0,8,0" />
                                        <Button Style="{StaticResource SecondaryButton}" Content="Promote ↑"
                                                Command="{Binding PromoteSkillCommand}" Margin="0,0,8,0" />
                                        <Button Style="{StaticResource SecondaryButton}" Content="Demote ↓"
                                                Command="{Binding DemoteSkillCommand}" Margin="0,0,8,0" />
                                    </StackPanel>

                                    <!-- Skill content -->
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBox Text="{Binding SelectedLibrarySkillContent, Mode=OneWay}" IsReadOnly="True"
                                                 FontFamily="Cascadia Code,Consolas" FontSize="12"
                                                 Background="Transparent" BorderThickness="0"
                                                 TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ══════════════ CREATE SKILL ══════════════ -->
                    <StackPanel Visibility="{Binding SelectedPage, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Create}">
                        <TextBlock Text="Create Skill" Style="{StaticResource PageTitle}" />

                        <Border Style="{StaticResource ContentCard}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Skill Name (optional)" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6" />
                                <TextBox Text="{Binding CreateSkillName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource StudioTextBox}" Margin="0,0,0,16" />

                                <TextBlock Text="Description" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6" />
                                <TextBox Text="{Binding CreateSkillDescription, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource StudioTextBox}" Height="100"
                                         TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" />

                                <Button Style="{StaticResource PrimaryButton}" Content="Create Skill"
                                        Command="{Binding InlineCreateSkillCommand}" Margin="0,16,0,0"
                                        HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ContentCard}" Visibility="{Binding OutputText, Converter={StaticResource StringEmptyToVisibilityConverter}}">
                            <TextBox Text="{Binding OutputText, Mode=OneWay}" IsReadOnly="True"
                                     FontFamily="Cascadia Code,Consolas" FontSize="12"
                                     Background="Transparent" BorderThickness="0" MaxHeight="200"
                                     VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>

                    <!-- ══════════════ IMPROVE SKILL ══════════════ -->
                    <StackPanel Visibility="{Binding SelectedPage, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Improve}">
                        <TextBlock Text="Improve Skill" Style="{StaticResource PageTitle}" />

                        <Border Style="{StaticResource ContentCard}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Select Skill" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6" />
                                <ComboBox ItemsSource="{Binding AvailableSkills}" SelectedItem="{Binding ImproveSelectedSkill}"
                                          DisplayMemberPath="DisplayName" Margin="0,0,0,16" Padding="8,6" />

                                <TextBlock Text="Improvement Goal (optional)" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6" />
                                <TextBox Text="{Binding ImproveSkillGoal, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource StudioTextBox}" Height="80"
                                         TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" />

                                <Button Style="{StaticResource PrimaryButton}" Content="Run Improvement"
                                        Command="{Binding InlineImproveSkillCommand}" Margin="0,16,0,0"
                                        HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ══════════════ TEST & EVALUATE ══════════════ -->
                    <StackPanel Visibility="{Binding SelectedPage, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Test}">
                        <TextBlock Text="Test &amp; Evaluate" Style="{StaticResource PageTitle}" />

                        <Border Style="{StaticResource ContentCard}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Select a skill from the Library to test, or use the controls below." FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" />

                                <UniformGrid Columns="3" Margin="0,0,0,4">
                                    <Button Style="{StaticResource PrimaryButton}" Content="Quick Test"
                                            Command="{Binding InlineTestSkillCommand}" Margin="0,0,8,0" />
                                    <Button Style="{StaticResource SecondaryButton}" Content="Create Benchmarks"
                                            Command="{Binding CreateBenchmarksCommand}" Margin="4,0" />
                                    <Button Style="{StaticResource SecondaryButton}" Content="Find External Skills"
                                            Command="{Binding FindExternalSkillsCommand}" Margin="8,0,0,0" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ContentCard}"
                                Visibility="{Binding TestStatus, Converter={StaticResource StringEmptyToVisibilityConverter}}">
                            <TextBlock Text="{Binding TestStatus}" FontSize="14" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>

                    <!-- ══════════════ AUTOMATION ══════════════ -->
                    <StackPanel Visibility="{Binding SelectedPage, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Automation}">
                        <TextBlock Text="Automation" Style="{StaticResource PageTitle}" />

                        <Border Style="{StaticResource ContentCard}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Continuous Improvement Loop" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8" />
                                <TextBlock Text="Automatically test and improve skills in the Testing tier until they reach a quality threshold."
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16" TextWrapping="Wrap" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="Quality Threshold:" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <Slider Minimum="10" Maximum="100" Value="{Binding AutomationThreshold}" Width="200"
                                            VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding AutomationThreshold, StringFormat='{}{0}%'}" FontSize="13"
                                               VerticalAlignment="Center" FontWeight="SemiBold" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="Max Iterations:" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <Slider Minimum="1" Maximum="20" Value="{Binding AutomationMaxIterations}" Width="200"
                                            VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding AutomationMaxIterations}" FontSize="13"
                                               VerticalAlignment="Center" FontWeight="SemiBold" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource PrimaryButton}" Content="Start Automation"
                                            Command="{Binding StartAutomationCommand}" Margin="0,0,12,0" />
                                    <Button Style="{StaticResource SecondaryButton}" Content="Stop"
                                            Command="{Binding StopAutomationCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ContentCard}"
                                Visibility="{Binding AutomationStatus, Converter={StaticResource StringEmptyToVisibilityConverter}}">
                            <TextBlock Text="{Binding AutomationStatus}" FontSize="14" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>

                    <!-- ══════════════ IMPORT ══════════════ -->
                    <StackPanel Visibility="{Binding SelectedPage, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Import}">
                        <TextBlock Text="Import Skills" Style="{StaticResource PageTitle}" />

                        <Border Style="{StaticResource ContentCard}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Import from Local Folder" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8" />
                                <TextBlock Text="Point to a folder containing a SKILL.md file. The skill will be imported to the Unverified library."
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" TextWrapping="Wrap" />

                                <DockPanel Margin="0,0,0,12">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="Import"
                                            Command="{Binding ImportFromFolderCommand}" Margin="12,0,0,0" />
                                    <TextBox Text="{Binding ImportPath, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource StudioTextBox}" />
                                </DockPanel>

                                <TextBlock Text="{Binding ImportStatus}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Visibility="{Binding ImportStatus, Converter={StaticResource StringEmptyToVisibilityConverter}}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ══════════════ LIBRARY MANAGEMENT ══════════════ -->
                    <StackPanel Visibility="{Binding SelectedPage, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Manage}">
                        <TextBlock Text="Library Management" Style="{StaticResource PageTitle}" />

                        <Border Style="{StaticResource ContentCard}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Promote and demote skills between tiers. Select a skill in the Library view, then use the actions below."
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16" TextWrapping="Wrap" />

                                <UniformGrid Columns="3" Margin="0,0,0,12">
                                    <Border Style="{StaticResource ContentCard}" Margin="0,0,8,0">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Unverified" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding LibraryUnverifiedCount}" FontSize="24" FontWeight="Bold"
                                                       HorizontalAlignment="Center" Foreground="{StaticResource WarningBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource ContentCard}" Margin="4,0">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="In Testing" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding LibraryTestingCount}" FontSize="24" FontWeight="Bold"
                                                       HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource ContentCard}" Margin="8,0,0,0">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Verified" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding LibraryVerifiedCount}" FontSize="24" FontWeight="Bold"
                                                       HorizontalAlignment="Center" Foreground="{StaticResource AccentBrush}" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource PrimaryButton}" Content="Promote Selected ↑"
                                            Command="{Binding PromoteSkillCommand}" Margin="0,0,12,0" />
                                    <Button Style="{StaticResource SecondaryButton}" Content="Demote Selected ↓"
                                            Command="{Binding DemoteSkillCommand}" Margin="0,0,12,0" />
                                    <Button Style="{StaticResource SecondaryButton}" Content="Audit Library"
                                            Command="{Binding MetaManageCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ══════════════ ANALYTICS ══════════════ -->
                    <StackPanel Visibility="{Binding SelectedPage, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Analytics}">
                        <TextBlock Text="Analytics" Style="{StaticResource PageTitle}" />

                        <UniformGrid Columns="3" Margin="0,0,0,20">
                            <Border Style="{StaticResource ContentCard}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Total Skills" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding LibrarySkillCount}" FontSize="28" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ContentCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="Run History" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding RunHistory.Count}" FontSize="28" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ContentCard}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Verified Rate" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock FontSize="28" FontWeight="Bold" Margin="0,4,0,0"
                                               Foreground="{StaticResource AccentBrush}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0}%">
                                                <Binding Path="LibraryVerifiedCount" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock Text="Run History" Style="{StaticResource SectionHeader}" />
                        <Border Style="{StaticResource ContentCard}">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding RunHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,4">
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding Timestamp, StringFormat='{}{0:g}'}"
                                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                                <TextBlock Text="{Binding DisplayName}" FontSize="13" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No runs recorded yet. Run a workflow to see history here."
                                           Visibility="{Binding RunHistory.Count, Converter={StaticResource CountToVisibilityConverter}}"
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,20" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ══════════════ SETTINGS ══════════════ -->
                    <StackPanel Visibility="{Binding SelectedPage, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Settings}">
                        <TextBlock Text="Settings" Style="{StaticResource PageTitle}" />

                        <Border Style="{StaticResource ContentCard}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Runtime Status" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8" />
                                <TextBlock Text="{Binding RuntimeStatus}" FontSize="13" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ContentCard}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Startup Checklist" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding StartupChecklist}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,4">
                                                <TextBlock Text="{Binding StatusGlyph}" FontSize="14" Width="24" />
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Description}" FontSize="12" Margin="8,0,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ContentCard}">
                            <StackPanel>
                                <TextBlock Text="Documentation" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding HelpResources}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,4">
                                                <TextBlock Text="{Binding StatusText}" FontSize="11" DockPanel.Dock="Right"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </DockPanel>

        <!-- ═══════════════════════════════════════════ -->
        <!-- RIGHT: AI Assistant Panel (Collapsible)     -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Column="2" Width="360"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0"
                Visibility="{Binding IsAssistantPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}"
                                Command="{Binding ClearChatCommand}" ToolTip="Clear conversation" Margin="4,0,0,0">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13" />
                        </Button>
                        <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}"
                                Command="{Binding ToggleAssistantCommand}" ToolTip="Close panel">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13" />
                        </Button>
                        <TextBlock Text="AI Assistant" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <!-- Input area at bottom -->
                <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="8">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                                Command="{Binding AssistantPromptCommand}" Content="Send"
                                Padding="14,6" Margin="8,0,0,0" VerticalAlignment="Bottom" />
                        <TextBox Text="{Binding AssistantPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource StudioTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="100"
                                 VerticalScrollBarVisibility="Auto" />
                    </DockPanel>
                </Border>

                <!-- Status -->
                <Border DockPanel.Dock="Bottom" Padding="12,4"
                        Visibility="{Binding IsAssistantBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding AssistantStatus}" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" FontStyle="Italic" />
                </Border>

                <!-- Chat History -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,8">
                    <ItemsControl ItemsSource="{Binding ChatHistory}"
                                  VirtualizingStackPanel.IsVirtualizing="True">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="4,4" Padding="10,8" CornerRadius="10"
                                        MaxWidth="320" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource ChatAssistantBrush}" />
                                            <Setter Property="HorizontalAlignment" Value="Left" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource ChatUserBrush}" />
                                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="13" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>