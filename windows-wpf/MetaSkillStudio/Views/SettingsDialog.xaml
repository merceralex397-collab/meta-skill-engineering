<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MetaSkillStudio.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings - Runtime Configuration" 
        Height="500" 
        Width="700"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Runtime Configuration" 
                      FontSize="20" 
                      FontWeight="SemiBold"
                      Foreground="{StaticResource PrimaryBrush}"
                      AutomationProperties.Name="Runtime Configuration Header"/>
            <TextBlock Text="Configure AI runtimes and models for each operational role." 
                      FontSize="12"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Role Configuration Tabs -->
        <TabControl Grid.Row="1"
                   x:Name="RoleTabs"
                   Background="{StaticResource SurfaceBrush}"
                   BorderBrush="{StaticResource BorderBrush}"
                   ToolTip="Select an operational role to configure its AI runtime and model"
                   AutomationProperties.Name="Role Configuration Tabs"
                   AutomationProperties.HelpText="Select a role to configure its runtime and model"
                   TabIndex="0">
            
            <!-- Create Tab -->
            <TabItem Header="Create" ToolTip="Configure AI runtime for creating new skills" TabIndex="0">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Creating Skills" 
                              FontSize="14" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"
                              AutomationProperties.Name="Creating Skills Section"/>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                  Text="Runtime:" 
                                  VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 x:Name="CreateRuntimeCombo"
                                 ItemsSource="{Binding AvailableRuntimes}"
                                 DisplayMemberPath="DisplayName"
                                 SelectedItem="{Binding CreateSelectedRuntime}"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                 ToolTip="Select the AI runtime (e.g., GPT, Claude) for creating new skills"
                                 AutomationProperties.Name="Create Runtime"
                                 AutomationProperties.HelpText="Select the AI runtime for creating skills"
                                 TabIndex="0"/>
                    </Grid>
                    
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                  Text="Model:" 
                                  VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 x:Name="CreateModelCombo"
                                 ItemsSource="{Binding CreateAvailableModels}"
                                 SelectedItem="{Binding CreateSelectedModel}"
                                 IsEditable="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                 ToolTip="Select or type the specific AI model (e.g., gpt-4, claude-sonnet-4-5)"
                                 AutomationProperties.Name="Create Model"
                                 AutomationProperties.HelpText="Select or enter the AI model for creating skills"
                                 TabIndex="0"/>
                    </Grid>
                    
                    <TextBlock Grid.Row="3" 
                              Text="This runtime will be used for creating new skills from scratch."
                              Foreground="{StaticResource TextSecondaryBrush}"
                              TextWrapping="Wrap"
                              VerticalAlignment="Bottom"
                              Margin="0,16,0,0"/>
                </Grid>
            </TabItem>
            
            <!-- Improve Tab -->
            <TabItem Header="Improve" ToolTip="Configure AI runtime for improving existing skills" TabIndex="0">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Improving Skills" 
                              FontSize="14" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"
                              AutomationProperties.Name="Improving Skills Section"/>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Runtime:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 ItemsSource="{Binding AvailableRuntimes}"
                                 DisplayMemberPath="DisplayName"
                                 SelectedItem="{Binding ImproveSelectedRuntime}"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                 ToolTip="Select the AI runtime for improving existing skills"
                                 AutomationProperties.Name="Improve Runtime"
                                 AutomationProperties.HelpText="Select the AI runtime for improving skills"
                                 TabIndex="0"/>
                    </Grid>
                    
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Model:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 ItemsSource="{Binding ImproveAvailableModels}"
                                 SelectedItem="{Binding ImproveSelectedModel}"
                                 IsEditable="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                 ToolTip="Select or type the specific AI model for skill improvement"
                                 AutomationProperties.Name="Improve Model"
                                 AutomationProperties.HelpText="Select or enter the AI model for improving skills"
                                 TabIndex="0"/>
                    </Grid>
                    
                    <TextBlock Grid.Row="3" 
                              Text="This runtime will be used for improving existing skills based on anti-pattern scans or specific goals."
                              Foreground="{StaticResource TextSecondaryBrush}"
                              TextWrapping="Wrap"
                              VerticalAlignment="Bottom"
                              Margin="0,16,0,0"/>
                </Grid>
            </TabItem>
            
            <!-- Test Tab -->
            <TabItem Header="Test" ToolTip="Configure AI runtime for testing, benchmarking, and evaluation" TabIndex="0">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Testing / Benchmarking / Evaluating" 
                              FontSize="14" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"
                              AutomationProperties.Name="Testing Section"/>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Runtime:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 ItemsSource="{Binding AvailableRuntimes}"
                                 DisplayMemberPath="DisplayName"
                                 SelectedItem="{Binding TestSelectedRuntime}"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                 ToolTip="Select the AI runtime for testing and evaluation"
                                 AutomationProperties.Name="Test Runtime"
                                 AutomationProperties.HelpText="Select the AI runtime for testing and benchmarking"
                                 TabIndex="0"/>
                    </Grid>
                    
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Model:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 ItemsSource="{Binding TestAvailableModels}"
                                 SelectedItem="{Binding TestSelectedModel}"
                                 IsEditable="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                 ToolTip="Select or type the specific AI model for testing"
                                 AutomationProperties.Name="Test Model"
                                 AutomationProperties.HelpText="Select or enter the AI model for testing"
                                 TabIndex="0"/>
                    </Grid>
                    
                    <TextBlock Grid.Row="3" 
                              Text="This runtime will be used for running evaluations, benchmarks, and trigger tests."
                              Foreground="{StaticResource TextSecondaryBrush}"
                              TextWrapping="Wrap"
                              VerticalAlignment="Bottom"
                              Margin="0,16,0,0"/>
                </Grid>
            </TabItem>
            
            <!-- Orchestrate Tab -->
            <TabItem Header="Orchestrate" ToolTip="Configure AI runtime for meta-library management and catalog operations" TabIndex="0">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Meta Management" 
                              FontSize="14" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"
                              AutomationProperties.Name="Orchestration Section"/>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Runtime:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 ItemsSource="{Binding AvailableRuntimes}"
                                 DisplayMemberPath="DisplayName"
                                 SelectedItem="{Binding OrchestrateSelectedRuntime}"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                 ToolTip="Select the AI runtime for orchestration and meta-operations"
                                 AutomationProperties.Name="Orchestrate Runtime"
                                 AutomationProperties.HelpText="Select the AI runtime for meta management"
                                 TabIndex="0"/>
                    </Grid>
                    
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Model:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 ItemsSource="{Binding OrchestrateAvailableModels}"
                                 SelectedItem="{Binding OrchestrateSelectedModel}"
                                 IsEditable="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                 ToolTip="Select or type the specific AI model for orchestration"
                                 AutomationProperties.Name="Orchestrate Model"
                                 AutomationProperties.HelpText="Select or enter the AI model for orchestration"
                                 TabIndex="0"/>
                    </Grid>
                    
                    <TextBlock Grid.Row="3" 
                              Text="This runtime will be used for meta-library management, catalog curation, and lifecycle operations."
                              Foreground="{StaticResource TextSecondaryBrush}"
                              TextWrapping="Wrap"
                              VerticalAlignment="Bottom"
                              Margin="0,16,0,0"/>
                </Grid>
            </TabItem>
            
            <!-- Judge Tab -->
            <TabItem Header="Judge" ToolTip="Configure AI runtime for quality judgment and evaluation" TabIndex="0">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="LLM Judge" 
                              FontSize="14" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"
                              AutomationProperties.Name="Judge Section"/>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Runtime:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 ItemsSource="{Binding AvailableRuntimes}"
                                 DisplayMemberPath="DisplayName"
                                 SelectedItem="{Binding JudgeSelectedRuntime}"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                 ToolTip="Select the AI runtime for quality judgment"
                                 AutomationProperties.Name="Judge Runtime"
                                 AutomationProperties.HelpText="Select the AI runtime for judging quality"
                                 TabIndex="0"/>
                    </Grid>
                    
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Model:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 ItemsSource="{Binding JudgeAvailableModels}"
                                 SelectedItem="{Binding JudgeSelectedModel}"
                                 IsEditable="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                 ToolTip="Select or type the specific AI model for quality judgment"
                                 AutomationProperties.Name="Judge Model"
                                 AutomationProperties.HelpText="Select or enter the AI model for judging"
                                 TabIndex="0"/>
                    </Grid>
                    
                    <TextBlock Grid.Row="3" 
                              Text="This runtime will be used as the judge for quality evaluation of skill outputs."
                              Foreground="{StaticResource TextSecondaryBrush}"
                              TextWrapping="Wrap"
                              VerticalAlignment="Bottom"
                              Margin="0,16,0,0"/>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- Runtime Detection Status -->
        <Border Grid.Row="2" 
                Background="#FFF9E6" 
                BorderBrush="#FFE082" 
                BorderThickness="1"
                CornerRadius="4"
                Padding="12"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                          Text="ℹ️" 
                          FontSize="16"
                          Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" 
                          x:Name="RuntimeStatusText"
                          Text="Scanning for available runtimes..."
                          TextWrapping="Wrap"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="Runtime Status"
                          AutomationProperties.LiveSetting="Polite"/>
            </Grid>
        </Border>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="3" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right"
                   Margin="0,16,0,0">
            <Button Style="{StaticResource SecondaryButton}"
                   Click="DetectRuntimesButton_Click"
                   Width="120"
                   Margin="0,0,8,0"
                   ToolTip="Scan system for available AI runtimes (Alt+D)"
                   AutomationProperties.Name="Detect Runtimes"
                   AutomationProperties.HelpText="Scan for available AI runtimes"
                   TabIndex="0">
                <AccessText>_Detect Runtimes</AccessText>
            </Button>
            <Button Style="{StaticResource PrimaryButton}"
                   Click="SaveButton_Click"
                   Width="80"
                   Margin="0,0,8,0"
                   IsDefault="True"
                   ToolTip="Save all runtime configuration changes (Alt+S, Enter)"
                   AutomationProperties.Name="Save Settings"
                   AutomationProperties.HelpText="Save runtime configuration"
                   TabIndex="0">
                <AccessText>_Save</AccessText>
            </Button>
            <Button Style="{StaticResource SecondaryButton}"
                   Click="CancelButton_Click"
                   IsCancel="True"
                   Width="80"
                   ToolTip="Close dialog without saving changes (Alt+C, Esc)"
                   AutomationProperties.Name="Cancel"
                   AutomationProperties.HelpText="Close without saving"
                   TabIndex="0">
                <AccessText>_Cancel</AccessText>
            </Button>
        </StackPanel>
    </Grid>
</Window>
