<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MetaSkillStudio.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings - AI Runtime Configuration" 
        Height="500" 
        Width="700"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="AI Runtime Configuration" 
                      FontSize="20" 
                      FontWeight="SemiBold"
                      Foreground="{StaticResource PrimaryBrush}"
                      AutomationProperties.Name="AI Runtime Configuration Header"/>
            <TextBlock Text="Configure the AI model used for each operational role. Powered by the OpenCode runtime." 
                      FontSize="12"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Role Configuration Tabs -->
        <TabControl Grid.Row="1"
                   x:Name="RoleTabs"
                   Background="{StaticResource SurfaceBrush}"
                   BorderBrush="{StaticResource BorderBrush}"
                   ToolTip="Select an operational role to configure its AI model"
                   AutomationProperties.Name="Role Configuration Tabs"
                   AutomationProperties.HelpText="Select a role to configure its AI model"
                   TabIndex="0">
            
            <!-- Create Tab -->
            <TabItem Header="Create" ToolTip="Configure AI model for creating new skills" TabIndex="0">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Creating Skills" 
                              FontSize="14" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"
                              AutomationProperties.Name="Creating Skills Section"/>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                  Text="Runtime:" 
                                  VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  x:Name="CreateRuntimeCombo"
                                  ItemsSource="{Binding AvailableRuntimes}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding CreateSelectedRuntime}"
                                  IsEnabled="False"
                                  VerticalContentAlignment="Center"
                                  Padding="8,6"
                                  ToolTip="AI execution runtime"
                                  AutomationProperties.Name="AI Runtime"
                                  AutomationProperties.HelpText="Displays the OpenCode runtime used for creating skills"
                                  TabIndex="0"/>
                    </Grid>
                    
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                  Text="Model:" 
                                  VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 x:Name="CreateModelCombo"
                                 ItemsSource="{Binding CreateAvailableModels}"
                                 SelectedItem="{Binding CreateSelectedModel}"
                                 IsEditable="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                  ToolTip="Select or type the AI model for this role"
                                  AutomationProperties.Name="AI Model Selection"
                                  AutomationProperties.HelpText="Select or enter the AI model"
                                  TabIndex="0"/>
                    </Grid>
                    
                    <TextBlock Grid.Row="3" 
                              Text="AI model used for creating new skills from scratch."
                              Foreground="{StaticResource TextSecondaryBrush}"
                              TextWrapping="Wrap"
                              VerticalAlignment="Bottom"
                              Margin="0,16,0,0"/>
                </Grid>
            </TabItem>
            
            <!-- Improve Tab -->
            <TabItem Header="Improve" ToolTip="Configure AI model for improving existing skills" TabIndex="0">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Improving Skills" 
                              FontSize="14" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"
                              AutomationProperties.Name="Improving Skills Section"/>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Runtime:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableRuntimes}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding ImproveSelectedRuntime}"
                                  IsEnabled="False"
                                  VerticalContentAlignment="Center"
                                  Padding="8,6"
                                  ToolTip="AI execution runtime"
                                  AutomationProperties.Name="AI Runtime"
                                  AutomationProperties.HelpText="AI execution runtime"
                                  TabIndex="0"/>
                    </Grid>
                    
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Model:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 ItemsSource="{Binding ImproveAvailableModels}"
                                 SelectedItem="{Binding ImproveSelectedModel}"
                                 IsEditable="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                  ToolTip="Select or type the AI model for this role"
                                  AutomationProperties.Name="AI Model Selection"
                                  AutomationProperties.HelpText="Select or enter the AI model"
                                  TabIndex="0"/>
                    </Grid>
                    
                    <TextBlock Grid.Row="3" 
                              Text="AI model used for improving existing skills based on anti-pattern scans or specific goals."
                              Foreground="{StaticResource TextSecondaryBrush}"
                              TextWrapping="Wrap"
                              VerticalAlignment="Bottom"
                              Margin="0,16,0,0"/>
                </Grid>
            </TabItem>
            
            <!-- Test Tab -->
            <TabItem Header="Test" ToolTip="Configure AI model for testing, benchmarking, and evaluation" TabIndex="0">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Testing / Benchmarking / Evaluating" 
                              FontSize="14" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"
                              AutomationProperties.Name="Testing Section"/>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Runtime:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableRuntimes}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding TestSelectedRuntime}"
                                  IsEnabled="False"
                                  VerticalContentAlignment="Center"
                                  Padding="8,6"
                                  ToolTip="AI execution runtime"
                                  AutomationProperties.Name="AI Runtime"
                                  AutomationProperties.HelpText="AI execution runtime"
                                  TabIndex="0"/>
                    </Grid>
                    
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Model:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 ItemsSource="{Binding TestAvailableModels}"
                                 SelectedItem="{Binding TestSelectedModel}"
                                 IsEditable="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                  ToolTip="Select or type the OpenCode model for testing"
                                  AutomationProperties.Name="AI Model Selection"
                                  AutomationProperties.HelpText="Select or enter the AI model"
                                  TabIndex="0"/>
                    </Grid>
                    
                    <TextBlock Grid.Row="3" 
                              Text="AI model used for running evaluations, benchmarks, and trigger tests."
                              Foreground="{StaticResource TextSecondaryBrush}"
                              TextWrapping="Wrap"
                              VerticalAlignment="Bottom"
                              Margin="0,16,0,0"/>
                </Grid>
            </TabItem>
            
            <!-- Orchestrate Tab -->
            <TabItem Header="Orchestrate" ToolTip="Configure AI model for library management and catalog operations" TabIndex="0">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Meta Management" 
                              FontSize="14" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"
                              AutomationProperties.Name="Orchestration Section"/>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Runtime:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableRuntimes}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding OrchestrateSelectedRuntime}"
                                  IsEnabled="False"
                                  VerticalContentAlignment="Center"
                                  Padding="8,6"
                                  ToolTip="AI execution runtime"
                                  AutomationProperties.Name="AI Runtime"
                                  AutomationProperties.HelpText="AI execution runtime"
                                  TabIndex="0"/>
                    </Grid>
                    
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Model:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 ItemsSource="{Binding OrchestrateAvailableModels}"
                                 SelectedItem="{Binding OrchestrateSelectedModel}"
                                 IsEditable="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                  ToolTip="Select or type the OpenCode model for orchestration"
                                  AutomationProperties.Name="AI Model Selection"
                                  AutomationProperties.HelpText="Select or enter the AI model"
                                  TabIndex="0"/>
                    </Grid>
                    
                    <TextBlock Grid.Row="3" 
                              Text="AI model used for library management, catalog curation, and lifecycle operations."
                              Foreground="{StaticResource TextSecondaryBrush}"
                              TextWrapping="Wrap"
                              VerticalAlignment="Bottom"
                              Margin="0,16,0,0"/>
                </Grid>
            </TabItem>
            
            <!-- Judge Tab -->
            <TabItem Header="Judge" ToolTip="Configure AI model for quality judgment and evaluation" TabIndex="0">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="LLM Judge" 
                              FontSize="14" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"
                              AutomationProperties.Name="Judge Section"/>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Runtime:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableRuntimes}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding JudgeSelectedRuntime}"
                                  IsEnabled="False"
                                  VerticalContentAlignment="Center"
                                  Padding="8,6"
                                  ToolTip="AI execution runtime"
                                  AutomationProperties.Name="AI Runtime"
                                  AutomationProperties.HelpText="AI execution runtime"
                                  TabIndex="0"/>
                    </Grid>
                    
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Model:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                 ItemsSource="{Binding JudgeAvailableModels}"
                                 SelectedItem="{Binding JudgeSelectedModel}"
                                 IsEditable="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,6"
                                  ToolTip="Select or type the AI model for this role"
                                  AutomationProperties.Name="AI Model Selection"
                                  AutomationProperties.HelpText="Select or enter the AI model"
                                  TabIndex="0"/>
                    </Grid>
                    
                    <TextBlock Grid.Row="3" 
                              Text="AI model used as the judge for quality evaluation of skill outputs."
                              Foreground="{StaticResource TextSecondaryBrush}"
                              TextWrapping="Wrap"
                              VerticalAlignment="Bottom"
                              Margin="0,16,0,0"/>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- AI Runtime Detection Status -->
        <Border Grid.Row="2" 
                Background="#FFF9E6" 
                BorderBrush="#FFE082" 
                BorderThickness="1"
                CornerRadius="4"
                Padding="12"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                          Text="ℹ️" 
                          FontSize="16"
                          Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" 
                          x:Name="RuntimeStatusText"
                          Text="Checking AI runtime availability..."
                          TextWrapping="Wrap"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="AI Runtime Status"
                          AutomationProperties.LiveSetting="Polite"/>
            </Grid>
        </Border>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="3" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right"
                   Margin="0,16,0,0">
            <Button Style="{StaticResource SecondaryButton}"
                   Click="DetectRuntimesButton_Click"
                    Width="120"
                    Margin="0,0,8,0"
                   ToolTip="Scan for the AI runtime and available models (Alt+D)"
                   AutomationProperties.Name="Detect AI Runtime"
                   AutomationProperties.HelpText="Scan for the AI runtime and available models"
                   TabIndex="0">
                <AccessText>_Detect Runtime</AccessText>
            </Button>
            <Button Style="{StaticResource PrimaryButton}"
                   Click="SaveButton_Click"
                   Width="80"
                    Margin="0,0,8,0"
                    IsDefault="True"
                   ToolTip="Save all model configuration changes (Alt+S, Enter)"
                    AutomationProperties.Name="Save Settings"
                   AutomationProperties.HelpText="Save model configuration"
                   TabIndex="0">
                <AccessText>_Save</AccessText>
            </Button>
            <Button Style="{StaticResource SecondaryButton}"
                   Click="CancelButton_Click"
                   IsCancel="True"
                   Width="80"
                   ToolTip="Close dialog without saving changes (Alt+C, Esc)"
                   AutomationProperties.Name="Cancel"
                   AutomationProperties.HelpText="Close without saving"
                   TabIndex="0">
                <AccessText>_Cancel</AccessText>
            </Button>
        </StackPanel>
    </Grid>
</Window>
