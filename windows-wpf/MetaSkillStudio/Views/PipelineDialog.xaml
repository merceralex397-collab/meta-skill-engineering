<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MetaSkillStudio.Views.PipelineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Pipeline Execution" 
        Height="600" 
        Width="800"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Run Pipeline" 
                      FontSize="20" 
                      FontWeight="SemiBold"
                      Foreground="{StaticResource PrimaryBrush}"
                      AutomationProperties.Name="Run Pipeline Header"/>
            <TextBlock Text="Execute multi-phase skill pipelines with state persistence" 
                      FontSize="12"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Configuration -->
        <Border Grid.Row="1" 
               Background="{StaticResource SurfaceBrush}"
               BorderBrush="{StaticResource BorderBrush}"
               BorderThickness="1"
               CornerRadius="8"
               Padding="16"
               Margin="0,0,0,16">
            <Grid IsEnabled="{Binding IsConfigurable}"
                 x:Name="ConfigurationPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Row="0" Grid.Column="0" 
                          Text="Pipeline Type:" 
                          VerticalAlignment="Center"
                          Margin="0,0,16,8"/>
                <ComboBox Grid.Row="0" Grid.Column="1"
                         x:Name="PipelineTypeCombo"
                         SelectedIndex="0"
                         Margin="0,0,0,8"
                         Padding="8,6"
                         ToolTip="Select the pipeline type to execute"
                         AutomationProperties.Name="Pipeline Type"
                         AutomationProperties.HelpText="Select the type of pipeline to execute"
                         TabIndex="0">
                    <ComboBoxItem Content="Creation Pipeline" Tag="creation" ToolTip="Create new skills from scratch" TabIndex="0"/>
                    <ComboBoxItem Content="Improvement Pipeline" Tag="improvement" ToolTip="Improve existing skills" TabIndex="0"/>
                    <ComboBoxItem Content="Library Management Pipeline" Tag="library-management" ToolTip="Manage skill library and catalog" TabIndex="0"/>
                </ComboBox>
                
                <TextBlock Grid.Row="1" Grid.Column="0" 
                          Text="Target Skill:" 
                          VerticalAlignment="Center"
                          Margin="0,0,16,8"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="TargetSkillTextBox"
                            Width="250"
                            VerticalContentAlignment="Center"
                            Padding="8,6"
                            Margin="0,0,8,8"
                            AutomationProperties.Name="Target Skill"
                            AutomationProperties.HelpText="Enter the name of the skill to process"
                            TabIndex="0"/>
                    <CheckBox x:Name="NewSkillCheckBox"
                             Content="New skill (no target)"
                             VerticalAlignment="Center"
                             Checked="NewSkillCheckBox_Checked"
                             Unchecked="NewSkillCheckBox_Unchecked"
                             AutomationProperties.Name="New skill checkbox"
                             AutomationProperties.HelpText="Check if this is a new skill without a target"
                             TabIndex="0"/>
                </StackPanel>
                
                <TextBlock Grid.Row="2" Grid.Column="0" 
                          Text="Brief/Goal:" 
                          VerticalAlignment="Top"
                          Margin="0,8,16,0"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                        x:Name="BriefTextBox"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        Height="60"
                        VerticalScrollBarVisibility="Auto"
                        Padding="8,6"
                        AutomationProperties.Name="Brief or Goal"
                        AutomationProperties.HelpText="Enter the brief or goal for the pipeline"
                        TabIndex="0"/>
            </Grid>
        </Border>
        
        <!-- Phase Progress -->
        <Border Grid.Row="2" 
               Background="{StaticResource SurfaceBrush}"
               BorderBrush="{StaticResource BorderBrush}"
               BorderThickness="1"
               CornerRadius="8"
               Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" 
                          Text="Pipeline Progress" 
                          FontSize="16" 
                          FontWeight="SemiBold"
                          Margin="0,0,0,12"
                          AutomationProperties.Name="Pipeline Progress Section"/>
                
                <!-- Empty State for Phases -->
                <TextBlock Grid.Row="1" 
                          Text="No pipeline phases to display. Start a pipeline to see progress."
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          TextWrapping="Wrap"
                          Margin="16"
                          Visibility="{Binding Phases.Count, Converter={StaticResource CountToVisibilityConverter}}"
                          AutomationProperties.Name="Empty State: No pipeline phases"/>
                
                <ScrollViewer Grid.Row="1" 
                             VerticalScrollBarVisibility="Auto"
                             Visibility="{Binding Phases.Count, Converter={StaticResource InverseCountToVisibilityConverter}}">
                    <ItemsControl x:Name="PhasesItemsControl"
                                 ItemsSource="{Binding Phases}"
                                 AutomationProperties.Name="Pipeline Phases List"
                                 TabIndex="0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Status Icon -->
                                    <TextBlock Grid.Column="0" 
                                              Text="{Binding StatusIcon}" 
                                              FontSize="16"
                                              VerticalAlignment="Center"
                                              AutomationProperties.Name="{Binding StatusText}"/>
                                    
                                    <!-- Phase Info -->
                                    <StackPanel Grid.Column="1" Margin="8,0">
                                        <TextBlock Text="{Binding SkillName}" 
                                                  FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding StatusText}" 
                                                  FontSize="11"
                                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    
                                    <!-- Progress -->
                                    <ProgressBar Grid.Column="2" 
                                                IsIndeterminate="{Binding IsRunning}"
                                                Value="{Binding Progress}"
                                                Maximum="100"
                                                Height="4"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVisibilityConverter}}"
                                                AutomationProperties.Name="{Binding SkillName, StringFormat='{}{0} Progress'}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
        
        <!-- Status and Buttons -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock x:Name="StatusMessage"
                          Text="{Binding StatusMessage}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          AutomationProperties.Name="Status Message"
                          AutomationProperties.LiveSetting="Polite"/>
                <ProgressBar x:Name="OverallProgress"
                            Value="{Binding OverallProgress}"
                            Maximum="100"
                            Width="200"
                            Height="4"
                            Margin="0,4,0,0"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                            AutomationProperties.Name="Overall Pipeline Progress"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="StartButton"
                       Style="{StaticResource PrimaryButton}"
                       Click="StartButton_Click"
                       Width="120"
                       Margin="0,0,8,0"
                       IsDefault="True"
                       ToolTip="Begin executing the selected pipeline (Alt+S, Enter)"
                       AutomationProperties.Name="Start Pipeline"
                       AutomationProperties.HelpText="Begin executing the pipeline"
                       TabIndex="0">
                    <AccessText>_Start Pipeline</AccessText>
                </Button>
                <Button x:Name="CancelButton"
                       Style="{StaticResource SecondaryButton}"
                       Click="CancelButton_Click"
                       IsCancel="True"
                       Width="80"
                       ToolTip="Cancel and close (Alt+X, Esc)"
                       AutomationProperties.Name="Cancel"
                       AutomationProperties.HelpText="Cancel and close dialog"
                       TabIndex="0">
                    <AccessText>_Cancel</AccessText>
                </Button>
            </StackPanel>
        </Grid>
        
        <!-- Busy Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
               Background="#CC000000"
               CornerRadius="8"
               Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
               x:Name="BusyOverlay"
               IsHitTestVisible="False"
               AutomationProperties.Name="Pipeline executing overlay"
               AutomationProperties.HelpText="Dialog is busy executing pipeline">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" 
                            Width="150" 
                            Height="4" 
                            Margin="0,0,0,12"
                            AutomationProperties.Name="Progress Indicator"/>
                <TextBlock Text="Executing pipeline..." 
                          Foreground="White"
                          FontSize="14"
                          HorizontalAlignment="Center"
                          AutomationProperties.Name="Executing message"
                          AutomationProperties.LiveSetting="Polite"/>
                <TextBlock x:Name="CurrentPhaseText"
                          Text="{Binding CurrentPhase}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="12"
                          Margin="0,8,0,0"
                          HorizontalAlignment="Center"
                          AutomationProperties.Name="Current Phase"
                          AutomationProperties.LiveSetting="Polite"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
