<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MetaSkillStudio.Views.BenchmarkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Create Benchmarks" 
        Height="350" 
        Width="550"
        MinWidth="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Create Benchmark Cases"
                      FontSize="18"
                      FontWeight="SemiBold"
                      Foreground="{StaticResource PrimaryBrush}"
                      AutomationProperties.Name="Create Benchmark Cases Header"/>
            <TextBlock Text="Generate evaluation test cases for a skill."
                      FontSize="12"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Skill Name -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                      Text="Skill Name:"
                      VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"
                    x:Name="SkillNameTextBox"
                    Text="{Binding SkillName, UpdateSourceTrigger=PropertyChanged}"
                    VerticalContentAlignment="Center"
                    Padding="8,6"
                    Validation.ErrorTemplate="{StaticResource ErrorTemplate}"
                    ToolTip="Enter the exact name of the skill to create benchmarks for"
                    AutomationProperties.Name="Skill Name"
                    AutomationProperties.HelpText="Enter the name of the skill to benchmark"
                    TabIndex="0"/>
        </Grid>

        <!-- Benchmark Goal -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                      Text="Benchmark Goal:"
                      Margin="0,0,0,4"/>
            <TextBox Grid.Row="1"
                    x:Name="GoalTextBox"
                    Text="{Binding BenchmarkGoal, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap"
                    AcceptsReturn="True"
                    Height="80"
                    VerticalScrollBarVisibility="Auto"
                    Padding="8,6"
                    Validation.ErrorTemplate="{StaticResource ErrorTemplate}"
                    ToolTip="Describe what the benchmark cases should test or validate"
                    AutomationProperties.Name="Benchmark Goal"
                    AutomationProperties.HelpText="Describe the goal or focus of the benchmark cases"
                    TabIndex="0"/>
        </Grid>

        <!-- Case Count -->
        <Grid Grid.Row="3" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                      Text="Case Count:"
                      VerticalAlignment="Center"/>
            <Slider Grid.Column="1"
                   x:Name="CaseCountSlider"
                   Value="{Binding CaseCount}"
                   Minimum="1"
                   Maximum="100"
                   Width="200"
                   VerticalAlignment="Center"
                   TickFrequency="1"
                   IsSnapToTickEnabled="True"
                   AutomationProperties.Name="Case Count Slider"
                   AutomationProperties.HelpText="Adjust the number of benchmark cases to generate"
                   TabIndex="0"/>
            <TextBlock Grid.Column="2"
                      x:Name="CaseCountDisplay"
                      Text="{Binding CaseCount}"
                      FontWeight="Bold"
                      FontSize="16"
                      Margin="12,0,0,0"
                      VerticalAlignment="Center"
                      AutomationProperties.Name="Case Count Display"
                      AutomationProperties.LiveSetting="Polite"/>
        </Grid>

        <!-- Description -->
        <TextBlock Grid.Row="4"
                  Text="Benchmark cases include trigger-positive, trigger-negative, and behavior validation scenarios."
                  FontSize="11"
                  Foreground="{StaticResource TextSecondaryBrush}"
                  TextWrapping="Wrap"
                  Margin="0,0,0,8"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5"
                   Orientation="Horizontal"
                   HorizontalAlignment="Right">
            <Button Style="{StaticResource PrimaryButton}"
                   Command="{Binding CreateBenchmarksCommand}"
                   Click="CreateButton_Click"
                   Width="80"
                   Margin="0,0,8,0"
                   IsDefault="True"
                   x:Name="CreateButton"
                   ToolTip="Generate benchmark test cases (Alt+C, Enter)"
                   AutomationProperties.Name="Create Benchmarks"
                   AutomationProperties.HelpText="Generate the benchmark cases"
                   TabIndex="0">
                <AccessText>_Create</AccessText>
            </Button>
            <Button Style="{StaticResource SecondaryButton}"
                   Click="CancelButton_Click"
                   IsCancel="True"
                   Width="80"
                   ToolTip="Cancel and close (Alt+X, Esc)"
                   AutomationProperties.Name="Cancel"
                   AutomationProperties.HelpText="Cancel benchmark creation"
                   TabIndex="0">
                <AccessText>_Cancel</AccessText>
            </Button>
        </StackPanel>

        <!-- Busy Overlay with Progress -->
        <Border Grid.Row="0" Grid.RowSpan="6"
               Background="#CC000000"
               CornerRadius="4"
               Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
               x:Name="BusyOverlay"
               IsHitTestVisible="False"
               AutomationProperties.Name="Creating benchmarks overlay"
               AutomationProperties.HelpText="Dialog is busy creating benchmark cases">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar x:Name="ProgressBar"
                            Width="200"
                            Height="4"
                            Margin="0,0,0,12"
                            Value="{Binding Progress}"
                            Maximum="100"
                            AutomationProperties.Name="Progress Bar"/>
                <TextBlock x:Name="ProgressText"
                          Text="{Binding ProgressText}"
                          Foreground="White"
                          FontSize="14"
                          HorizontalAlignment="Center"
                          AutomationProperties.Name="Progress Text"
                          AutomationProperties.LiveSetting="Polite"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
