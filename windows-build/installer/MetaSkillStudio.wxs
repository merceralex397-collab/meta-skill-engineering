<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX Toolset Source File for Meta Skill Studio Installer
  Compatible with WiX v3.11 and v4.x
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <?define ProductName = "Meta Skill Studio" ?>
  <?define ProductVersion = "1.0.0" ?>
  <?define ProductCode = "*" ?>
  <?define UpgradeCode = "12345678-1234-1234-1234-123456789012" ?>
  <?define Manufacturer = "Meta Skill Studio Team" ?>
  <?define ExeName = "MetaSkillStudio.exe" ?>

  <Product Id="$(var.ProductCode)"
           Name="$(var.ProductName)"
           Language="1033"
           Version="$(var.ProductVersion)"
           Manufacturer="$(var.Manufacturer)"
           UpgradeCode="$(var.UpgradeCode)">
    
    <Package InstallerVersion="200"
             Compressed="yes"
             InstallScope="perMachine"
             Platform="x64"
             Manufacturer="$(var.Manufacturer)"
             Description="Meta Skill Studio Installer"
             Comments="Professional AI Skill Management Tool" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Features -->
    <Feature Id="ProductFeature" Title="Meta Skill Studio" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="Shortcuts" />
    </Feature>

    <!-- Properties -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <Property Id="ARPNOMODIFY" Value="yes" Secure="yes" />
    <Property Id="ARPNOREPAIR" Value="yes" Secure="yes" />
    <Property Id="ARPPRODUCTICON" Value="app.ico" />
    
    <!-- License -->
    <WixVariable Id="WixUILicenseRtf" Value="$(var.ProjectDir)..\resources\license.rtf" />
    <WixVariable Id="WixUIBannerBmp" Value="$(var.ProjectDir)..\resources\banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="$(var.ProjectDir)..\resources\dialog.bmp" />

    <!-- UI -->
    <UIRef Id="WixUI_InstallDir" />
    <UIRef Id="WixUI_ErrorProgressText" />

    <!-- Directories -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Meta Skill Studio">
          
          <!-- Main Components -->
          <Component Id="MainExecutable" Guid="*" Win64="yes">
            <File Id="MetaSkillStudioEXE" 
                  Name="$(var.ExeName)" 
                  Source="$(var.ProjectDir)..\dist\$(var.ExeName)"
                  KeyPath="yes">
            </File>
          </Component>

          <!-- Registry Entries -->
          <Component Id="RegistryEntries" Guid="*" Win64="yes">
            <RegistryKey Root="HKLM" Key="Software\Meta Skill Studio">
              <RegistryValue Type="string" Name="InstallDir" Value="[INSTALLFOLDER]" />
              <RegistryValue Type="string" Name="Version" Value="$(var.ProductVersion)" />
            </RegistryKey>
          </Component>

        </Directory>
      </Directory>

      <!-- Start Menu Shortcuts -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Meta Skill Studio">
          <Component Id="ApplicationShortcuts" Guid="*">
            <Shortcut Id="ApplicationStartMenuShortcut"
                      Name="Meta Skill Studio"
                      Description="AI Skill Management Tool"
                      Target="[#MetaSkillStudioEXE]"
                      WorkingDirectory="INSTALLFOLDER"
                      Icon="app.ico" />
            <Shortcut Id="UninstallProduct"
                      Name="Uninstall Meta Skill Studio"
                      Description="Uninstalls Meta Skill Studio"
                      Target="[System64Folder]msiexec.exe"
                      Arguments="/x [ProductCode]" />
            <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\Meta Skill Studio" 
                          Name="installed" Type="integer" Value="1" 
                          KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>

      <!-- Desktop Shortcut (optional, controlled by property) -->
      <Directory Id="DesktopFolder">
        <Component Id="DesktopShortcut" Guid="*">
          <Condition>INSTALLDESKTOPSHORTCUT</Condition>
          <Shortcut Id="ApplicationDesktopShortcut"
                    Name="Meta Skill Studio"
                    Description="AI Skill Management Tool"
                    Target="[#MetaSkillStudioEXE]"
                    WorkingDirectory="INSTALLFOLDER"
                    Icon="app.ico" />
          <RegistryValue Root="HKCU" Key="Software\Meta Skill Studio" 
                        Name="desktopshortcut" Type="integer" Value="1" />
        </Component>
      </Directory>

    </Directory>

    <!-- Icon -->
    <Icon Id="app.ico" SourceFile="$(var.ProjectDir)..\resources\app.ico" />

    <!-- Component Groups -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="RegistryEntries" />
    </ComponentGroup>

    <ComponentGroup Id="Shortcuts">
      <ComponentRef Id="ApplicationShortcuts" />
      <ComponentRef Id="DesktopShortcut" />
    </ComponentGroup>

    <!-- Custom Actions -->
    <CustomAction Id="LaunchApplication" 
                  FileKey="MetaSkillStudioEXE" 
                  ExeCommand="" 
                  Return="asyncNoWait" />

    <!-- Install Execute Sequence -->
    <InstallExecuteSequence>
      <Custom Action="LaunchApplication" After="InstallFinalize">
        NOT Installed AND NOT UIANDADMINDISABLED
      </Custom>
    </InstallExecuteSequence>

  </Product>
</Wix>
